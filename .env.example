# App
NEXT_PUBLIC_APP_URL=https://devtools.catiteo.com
NEXT_PUBLIC_APP_NAME=DevToolbox
PORT=3000

# IA — OpenRouter (recomendado: API compatível com OpenAI)
# Crie a chave em https://openrouter.ai/keys — NUNCA commite o valor real
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=meta-llama/llama-3.1-8b-instruct

# Outros provedores OpenAI-compatible (descomente e ajuste)
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Estúdio de Estampas — tamanho máximo de upload (MB)
MAX_UPLOAD_MB=25

# Alternativa: Ollama no mesmo VPS (ignorado se OPENAI_API_KEY estiver definida)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3
