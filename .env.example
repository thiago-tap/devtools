# App
NEXT_PUBLIC_APP_URL=https://devtools.catiteo.com
NEXT_PUBLIC_APP_NAME=DevToolbox
PORT=3000

# IA — OpenRouter (recomendado: API compatível com OpenAI)
# Crie a chave em https://openrouter.ai/keys — NUNCA commite o valor real
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=meta-llama/llama-3.1-8b-instruct

# Outros provedores OpenAI-compatible (descomente e ajuste)
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Estúdio de Estampas — upload (MB)
MAX_UPLOAD_MB=25

# Remover fundo — URL do serviço Rembg (mesma rede Docker / Easypanel), ex.: http://rembg:7000
# Documentação: docs/easypanel-setup.md
REMBG_BASE_URL=
# Opcional: timeout em ms (padrão 180000)
# REMBG_TIMEOUT_MS=180000
# Opcional: máximo de operações Rembg por IP por minuto (padrão 12)
# REMBG_RATE_LIMIT_PER_MIN=12

# Alternativa: Ollama no mesmo VPS (ignorado se OPENAI_API_KEY estiver definida)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3

# --- Docker Compose (stack local em docker-compose.yml) ---
# app + rembg:  docker compose up --build
# + monitor:    docker compose --profile monitoring up --build  → Uptime Kuma em http://localhost:3001
# REMBG_BASE_URL vazio no .env usa padrão http://rembg:7000 dentro do Compose.
